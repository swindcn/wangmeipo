    {
      "name": "createShareToken",
      "runtime": "Nodejs18.15",
      "timeout": 30
    },
    {
      "name": "drainParseQueue",
      "runtime": "Nodejs18.15",
      "timeout": 120
    },
    {
      "name": "getCandidateDetail",
      "runtime": "Nodejs18.15",
      "timeout": 30
    },
    {
      "name": "getDashboardSummary",
      "runtime": "Nodejs18.15",
      "timeout": 30
    },
    {
      "name": "getMatchData",
      "runtime": "Nodejs18.15",
      "timeout": 30
    },
    {
      "name": "getPermissionData",
      "runtime": "Nodejs18.15",
      "timeout": 30
    },
    {
      "name": "grantCandidatePermission",
      "runtime": "Nodejs18.15",
      "timeout": 30
    },
    {
      "name": "ingestOfficialAccountMessage",
      "runtime": "Nodejs18.15",
      "timeout": 120
    },
    {
      "name": "listMyAccess",
      "runtime": "Nodejs18.15",
      "timeout": 30
    },
    {
      "name": "listReviewQueue",
      "runtime": "Nodejs18.15",
      "timeout": 30
    },
    {
      "name": "recordMatch",
      "runtime": "Nodejs18.15",
      "timeout": 30
    },
    {
      "name": "reviewParsedCandidate",
      "runtime": "Nodejs18.15",
      "timeout": 30
    },
    {
      "name": "submitCandidateProfile",
      "runtime": "Nodejs18.15",
      "timeout": 60
