        "LLM_PROVIDER": "{{env.LLM_PROVIDER}}",
        "MIMO_API_KEY": "{{env.MIMO_API_KEY}}",
        "MIMO_LLM_MODEL": "{{env.MIMO_LLM_MODEL}}",
        "MIMO_BASE_URL": "{{env.MIMO_BASE_URL}}",
        "ARK_API_KEY": "{{env.ARK_API_KEY}}",
        "ARK_LLM_MODEL": "{{env.ARK_LLM_MODEL}}",
        "ARK_BASE_URL": "{{env.ARK_BASE_URL}}",
        "OPENAI_API_KEY": "{{env.OPENAI_API_KEY}}",
        "OPENAI_LLM_MODEL": "{{env.OPENAI_LLM_MODEL}}",
        "OPENAI_BASE_URL": "{{env.OPENAI_BASE_URL}}",
        "LLM_REQUEST_TIMEOUT_MS": "{{env.LLM_REQUEST_TIMEOUT_MS}}",
        "OPENAI_REQUEST_TIMEOUT_MS": "{{env.OPENAI_REQUEST_TIMEOUT_MS}}"
      }
    },
    {
      "name": "upsertCurrentUser",
      "runtime": "Nodejs18.15",
      "timeout": 30
    },
    {
      "name": "runParsePipeline",
      "runtime": "Nodejs18.15",
      "timeout": 300,
      "envVariables": {
        "LLM_PROVIDER": "{{env.LLM_PROVIDER}}",
        "MIMO_API_KEY": "{{env.MIMO_API_KEY}}",
        "MIMO_LLM_MODEL": "{{env.MIMO_LLM_MODEL}}",
        "MIMO_BASE_URL": "{{env.MIMO_BASE_URL}}",
        "ARK_API_KEY": "{{env.ARK_API_KEY}}",
        "ARK_LLM_MODEL": "{{env.ARK_LLM_MODEL}}",
        "ARK_VISION_MODEL": "{{env.ARK_VISION_MODEL}}",
        "ARK_BASE_URL": "{{env.ARK_BASE_URL}}",
        "OPENAI_API_KEY": "{{env.OPENAI_API_KEY}}",
        "OPENAI_LLM_MODEL": "{{env.OPENAI_LLM_MODEL}}",
        "OPENAI_VISION_MODEL": "{{env.OPENAI_VISION_MODEL}}",
        "OPENAI_BASE_URL": "{{env.OPENAI_BASE_URL}}",
        "LLM_REQUEST_TIMEOUT_MS": "{{env.LLM_REQUEST_TIMEOUT_MS}}",
        "OPENAI_REQUEST_TIMEOUT_MS": "{{env.OPENAI_REQUEST_TIMEOUT_MS}}",
