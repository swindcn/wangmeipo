.photo-grid {
  display: grid;
  grid-template-columns: repeat(2, minmax(0, 1fr));
  gap: 16rpx;
}

.photo-card {
  height: 220rpx;
  border-radius: 20rpx;
  background: linear-gradient(135deg, #eadccf, #f7f0e7);
  color: #8a6244;
  display: flex;
  align-items: center;
  justify-content: center;
}

.photo-image {
  width: 100%;
  height: 220rpx;
  border-radius: 20rpx;
  background: #efe4d6;
}

.photo-locked {
  border: 1rpx dashed #d6bca3;
  border-radius: 20rpx;
  padding: 24rpx;
  color: #8a7463;
  background: #fcf7f1;
}

.ghost-button {
  background: #efe1d0;
  color: #7f5330;
}
