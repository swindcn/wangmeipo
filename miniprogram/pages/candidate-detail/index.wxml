<view class="detail-page">
  <view wx:if="{{loading}}" class="muted loading">加载中...</view>

  <view wx:if="{{candidate}}" class="top-actions" style="top: {{navBarTop}}px; height: {{navBarHeight}}px; padding-right: {{navBarRight}}px;">
    <view class="top-icon back-icon" bindtap="handleBack">
      <image class="top-icon-image" src="../../assets/icons/detail-back.png" mode="aspectFit" />
    </view>
    <view wx:if="{{candidate.canUseKeyActions}}" class="manager-icons">
      <picker wx:if="{{!candidate.isTrashMode}}" mode="date" start="{{todayDate}}" bindchange="handleSubscriptionDateChange">
        <view class="top-icon manage-icon {{candidate.isSubscribed ? 'subscribed' : ''}}">
          <image
            class="top-icon-image"
            src="{{candidate.isSubscribed ? '../../assets/icons/detail-subscribe-on.png' : '../../assets/icons/detail-subscribe-off.png'}}"
            mode="aspectFit"
          />
        </view>
      </picker>
      <view wx:if="{{!candidate.isTrashMode}}" class="top-icon manage-icon" bindtap="handleEdit">
        <image class="top-icon-image" src="../../assets/icons/detail-edit.png" mode="aspectFit" />
      </view>
      <view wx:if="{{!candidate.isTrashMode}}" class="top-icon manage-icon danger" bindtap="handleDelete">
        <image class="top-icon-image" src="../../assets/icons/detail-delete.png" mode="aspectFit" />
      </view>
      <view wx:if="{{candidate.isTrashMode}}" class="top-icon restore-icon" bindtap="handleRestore">复</view>
    </view>
  </view>

  <view wx:if="{{candidate}}" class="detail-content">
    <view class="hero-card">
      <swiper
        wx:if="{{candidate.displayPhotos.length}}"
        class="hero-swiper"
        current="{{currentPhotoIndex}}"
        circular="{{candidate.displayPhotos.length > 1}}"
        bindchange="handlePhotoChange"
      >
        <block wx:for="{{candidate.displayPhotos}}" wx:key="value">
          <swiper-item>
            <view class="hero-photo-wrap" bindtap="handlePreviewPhoto">
              <image wx:if="{{item.type === 'url'}}" class="hero-photo {{candidate.isPrivateLocked ? 'blurred' : ''}}" src="{{item.value}}" mode="aspectFill" />
              <view wx:else class="hero-placeholder {{candidate.isPrivateLocked ? 'blurred' : ''}}">照片 {{item.value}}</view>
              <view class="hero-watermark">
                <text>王美婆</text><text>王美婆</text><text>王美婆</text>
                <text>王美婆</text><text>王美婆</text><text>王美婆</text>
                <text>王美婆</text><text>王美婆</text><text>王美婆</text>
              </view>
              <view wx:if="{{candidate.isPrivateLocked}}" class="photo-lock">私密分享 · 照片未开放</view>
            </view>
          </swiper-item>
        </block>
      </swiper>
      <view wx:else class="hero-empty">暂无照片</view>

      <view class="hero-tags">
        <text wx:if="{{candidate.gender}}" class="hero-tag">{{candidate.gender}}</text>
        <text wx:if="{{candidate.age}}" class="hero-tag">{{candidate.age}}岁</text>
        <text wx:if="{{candidate.occupation}}" class="hero-tag">{{candidate.occupation}}</text>
        <text wx:if="{{candidate.education}}" class="hero-tag">{{candidate.education}}</text>
        <text wx:for="{{candidate.tags}}" wx:key="*this" class="hero-tag">{{item}}</text>
      </view>

      <view wx:if="{{candidate.displayPhotos.length > 1}}" class="photo-dots">
        <text wx:for="{{candidate.displayPhotos}}" wx:key="*this" class="{{index === currentPhotoIndex ? 'dot active' : 'dot'}}"></text>
      </view>

    </view>

    <view class="info-card">
      <view class="card-head">
        <view>
          <view class="section-title">会员详情</view>
          <view class="muted">编号：{{candidate.candidateCode || '-'}}</view>
        </view>
        <text wx:if="{{candidate.shareMode === 'public'}}" class="permission-pill">公开分享</text>
      </view>

      <view class="grid-two">
        <view><text class="muted">姓名</text><view>{{candidate.canViewName ? (candidate.name || '-') : '当前权限不可见'}}</view></view>
        <view><text class="muted">性别</text><view>{{candidate.gender || '未知'}}</view></view>
        <view><text class="muted">生于</text><view>{{candidate.birthYear || '-'}}</view></view>
        <view><text class="muted">年龄</text><view>{{candidate.age || '-'}}</view></view>
        <view><text class="muted">属相</text><view>{{candidate.zodiac || '-'}}</view></view>
        <view><text class="muted">身高</text><view>{{candidate.heightCm || '-'}} cm</view></view>
        <view><text class="muted">体重</text><view>{{candidate.weightKg || '-'}} kg</view></view>
        <view><text class="muted">学历</text><view>{{candidate.education || '-'}}</view></view>
        <view><text class="muted">职业</text><view>{{candidate.occupation || '-'}}</view></view>
        <view><text class="muted">祖籍</text><view>{{candidate.ancestralHome || '-'}}</view></view>
        <view><text class="muted">宗教</text><view>{{candidate.religion || '-'}}</view></view>
      </view>
    </view>

    <view class="info-card">
      <view class="section-title">资料摘要</view>
      <view class="summary-line">性格：{{candidate.personality || '暂无性格描述'}}</view>
      <view class="summary-line">爱好：{{candidate.hobbies.length ? candidate.hobbies.join('、') : '暂无'}}</view>
      <view class="summary-block two-line-summary">
        <text class="summary-block-label">家庭情况：</text>
        <text class="summary-block-content">{{candidate.familyBackground || '暂无'}}</text>
      </view>
      <view class="summary-block two-line-summary">
        <text class="summary-block-label">择偶要求：</text>
        <text class="summary-block-content muted">{{candidate.matchRequirements || '暂无'}}</text>
      </view>
    </view>

    <view class="info-card">
      <view class="section-title">敏感信息</view>
      <view class="summary-line">常住地址：{{candidate.currentAddress || '暂无'}}</view>
      <view class="summary-line">联系电话：{{candidate.canViewPhone ? (candidate.phone || '-') : '当前权限不可见'}}</view>
      <view class="summary-block two-line-summary">
        <text class="summary-block-label">房产情况：</text>
        <text class="summary-block-content">{{candidate.assetsText || '暂无'}}</text>
      </view>
      <view class="summary-line">订阅到期：{{candidate.subscriptionExpiresText || '未订阅'}}</view>
      <view class="muted">照片权限：{{candidate.canViewPhotos ? '可见' : '私密模式未开放'}}</view>
    </view>

    <view class="info-card" wx:if="{{candidate.profileStatus === 'pending_review'}}">
      <view class="section-title">审核操作</view>
      <view class="muted review-copy">当前资料仍在待校正队列。</view>
      <button class="action-button" bindtap="handleApprove">发布该资料</button>
    </view>

    <view class="action-list review-request-actions" wx:if="{{requestId && candidate.canUseKeyActions}}">
      <button class="action-button" data-action="approve" bindtap="handleReviewViewRequest">同意想看</button>
      <button class="action-button reject-button" data-action="reject" bindtap="handleReviewViewRequest">拒绝想看</button>
    </view>

    <view class="info-card" wx:if="{{shareToken}}">
      <view class="section-title">{{shareModeText}}</view>
      <view class="muted">{{shareToken}}</view>
      <view class="muted share-path" wx:if="{{sharePath}}">{{sharePath}}</view>
    </view>

    <view class="action-list" wx:if="{{candidate.isTrashMode}}">
      <button class="action-button" bindtap="handleRestore">恢复会员资料</button>
    </view>
  </view>

  <view wx:if="{{candidate && !requestId && !candidate.isTrashMode && candidate.canUseKeyActions}}" class="fixed-action-bar">
    <button class="bar-action" open-type="share" data-mode="public" disabled="{{!publicSharePath || !shareCardReady}}" bindtap="handlePublicShareTap">
      <image class="bar-icon-image" src="../../assets/icons/detail-action-share-public.png" mode="aspectFit" />
      <text class="bar-label">{{shareCardReady ? '公开分享' : '生成中'}}</text>
    </button>
    <button class="bar-action" open-type="share" data-mode="private" disabled="{{!privateSharePath || !shareCardReady}}" bindtap="handlePrivateShareTap">
      <image class="bar-icon-image" src="../../assets/icons/detail-action-share-private.png" mode="aspectFit" />
      <text class="bar-label">{{shareCardReady ? '私密分享' : '生成中'}}</text>
    </button>
    <button class="bar-action" loading="{{posterGenerating}}" disabled="{{posterGenerating}}" bindtap="handleSharePoster">
      <image class="bar-icon-image" src="../../assets/icons/detail-action-poster.png" mode="aspectFit" />
      <text class="bar-label">海报分享</text>
    </button>
    <button class="bar-action" bindtap="handleGoMatch">
      <image class="bar-icon-image" src="../../assets/icons/detail-action-match.png" mode="aspectFit" />
      <text class="bar-label">添加匹配</text>
    </button>
  </view>

  <view wx:if="{{candidate && !requestId && !candidate.isTrashMode && !candidate.canUseKeyActions && !candidate.hasKeyDataAccess}}" class="fixed-action-bar viewer-bar">
    <button class="viewer-want-button {{candidate.viewRequestPending ? 'pending' : ''}}" disabled="{{candidate.viewRequestPending}}" bindtap="handleViewRequest">
      <text class="bar-icon">♥</text>
      <text>{{candidate.viewRequestButtonText}}</text>
    </button>
  </view>

  <view wx:if="{{previewVisible}}" class="photo-preview-mask" bindtap="closePreview">
    <swiper
      class="photo-preview-swiper"
      current="{{previewPhotoIndex}}"
      circular="{{previewPhotos.length > 1}}"
      bindchange="handlePreviewChange"
      catchtap="stopPreviewTap"
    >
      <block wx:for="{{previewPhotos}}" wx:key="*this">
        <swiper-item>
          <view class="photo-preview-item" bindtap="closePreview">
            <image class="photo-preview-image" src="{{item}}" mode="aspectFit" />
            <view class="preview-watermark">
              <text>王美婆</text><text>王美婆</text><text>王美婆</text>
              <text>王美婆</text><text>王美婆</text><text>王美婆</text>
              <text>王美婆</text><text>王美婆</text><text>王美婆</text>
              <text>王美婆</text><text>王美婆</text><text>王美婆</text>
            </view>
          </view>
        </swiper-item>
      </block>
    </swiper>
    <view class="photo-preview-close" bindtap="closePreview">×</view>
    <view wx:if="{{previewPhotos.length > 1}}" class="photo-preview-count">{{previewPhotoIndex + 1}} / {{previewPhotos.length}}</view>
  </view>

  <canvas type="2d" id="posterCanvas" class="poster-canvas"></canvas>
</view>
