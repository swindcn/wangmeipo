<view class="settings-page">
  <view class="setting-list">
    <view class="setting-row avatar-row" bindtap="openAvatarModal">
      <text class="setting-label">头像</text>
      <view class="avatar-button">
        <image wx:if="{{profile.avatarUrl}}" class="avatar" src="{{profile.avatarUrl}}" mode="aspectFill" />
        <view wx:else class="avatar placeholder">我</view>
      </view>
      <image class="arrow" src="../../assets/icons/common-chevron-right.png" mode="aspectFit" />
    </view>

    <view class="setting-row" bindtap="openNicknameModal">
      <text class="setting-label">昵称</text>
      <text class="setting-value">{{profile.nickname || '未设置'}}</text>
      <image class="arrow" src="../../assets/icons/common-chevron-right.png" mode="aspectFit" />
    </view>

    <view class="setting-row">
      <text class="setting-label">手机号</text>
      <text class="setting-value">{{profile.phoneText || '未绑定'}}</text>
    </view>

    <view class="setting-row" bindtap="openPasswordSettings">
      <text class="setting-label">密码</text>
      <text class="setting-value">{{profile.hasPassword ? '已设置' : '未设置'}}</text>
      <image class="arrow" src="../../assets/icons/common-chevron-right.png" mode="aspectFit" />
    </view>
  </view>

  <button class="save-button" loading="{{saving}}" disabled="{{saving}}" bindtap="handleSave">保存资料</button>
  <button class="logout-button" bindtap="handleLogout">退出登录</button>

  <view wx:if="{{nicknameModalVisible}}" class="modal-mask">
    <view class="nickname-modal">
      <view class="modal-title">昵称设置</view>
      <input class="modal-input" type="text" value="{{draftNickname}}" bindinput="handleDraftNicknameInput" />
      <view class="modal-link-wrap">
        <input class="wechat-nickname-input" type="nickname" bindinput="handleWechatNicknameInput" placeholder="使用微信昵称" />
      </view>
      <view class="modal-actions">
        <button class="modal-cancel" bindtap="closeNicknameModal">取消</button>
        <button class="modal-save" loading="{{saving}}" disabled="{{saving}}" bindtap="saveNickname">保存</button>
      </view>
    </view>
  </view>

  <view wx:if="{{avatarModalVisible}}" class="modal-mask">
    <view class="avatar-modal">
      <view class="modal-title">头像设置</view>
      <view class="avatar-preview-wrap">
        <image wx:if="{{draftAvatarUrl}}" class="avatar-preview" src="{{draftAvatarUrl}}" mode="aspectFill" />
        <view wx:else class="avatar-preview placeholder">我</view>
      </view>
      <button class="avatar-select-button" bindtap="chooseAvatarFromAlbum">从相册选取</button>
      <button class="avatar-wechat-button" open-type="chooseAvatar" bindchooseavatar="handleChooseWechatAvatar">使用微信头像</button>
      <view class="modal-actions">
        <button class="modal-cancel" bindtap="closeAvatarModal">取消</button>
        <button class="modal-save" loading="{{saving}}" disabled="{{saving}}" bindtap="saveAvatar">保存</button>
      </view>
    </view>
  </view>
</view>
