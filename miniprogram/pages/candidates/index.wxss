page {
  background: #ffffff;
}

.manage-page {
  min-height: 100vh;
  padding-bottom: 150rpx;
  background: #ffffff;
}

.menu-list {
  background: #ffffff;
}

.menu-row {
  height: 148rpx;
  display: flex;
  align-items: center;
  padding: 0 34rpx;
  border-bottom: 1rpx solid #eeeeee;
  box-sizing: border-box;
}

.menu-icon {
  width: 48rpx;
  margin-right: 28rpx;
  font-size: 40rpx;
  font-weight: 800;
  text-align: center;
}

.menu-icon.red {
  color: #c9342e;
}

.menu-icon.blue {
  color: #4a9cf0;
}

.menu-icon.green {
  color: #5b8526;
}

.menu-label {
  flex: 1;
  color: #666666;
  font-size: 32rpx;
  font-weight: 800;
}

.menu-badge {
  margin-right: 18rpx;
  color: #c9342e;
  font-size: 32rpx;
  font-weight: 800;
}

.menu-arrow {
  color: #999999;
  font-size: 58rpx;
  font-weight: 200;
  line-height: 58rpx;
}
