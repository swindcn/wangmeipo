<view class="assistant-page">
  <view class="assistant-nav" style="height: {{navTopGap}}rpx;">
    <view class="assistant-nav-title">搜索</view>
  </view>

  <scroll-view class="chat-scroll" style="padding-top: {{navTopGap}}rpx;" scroll-y>
    <view class="hero">
      <view class="hero-kicker">AI 搜索小助理</view>
      <view class="hero-copy">用自然语言描述需求，我会先按资料库帮你筛出可能合适的会员。</view>
    </view>

    <view class="chat-list">
      <block wx:for="{{messages}}" wx:key="index">
        <view class="message-row {{item.role === 'user' ? 'user' : 'assistant'}}">
          <view class="message-bubble {{item.pending ? 'pending' : ''}}">
            <text>{{item.text}}</text>
            <text wx:if="{{item.pending}}" class="typing-dot">·</text>
          </view>
        </view>
      </block>
    </view>

    <view wx:if="{{candidates.length}}" class="result-list">
      <view class="result-title">推荐会员</view>
      <block wx:for="{{candidates}}" wx:key="_id">
        <view class="candidate-row" data-id="{{item._id}}" bindtap="handleOpenCandidate">
          <image wx:if="{{item.photoUrl}}" class="candidate-photo {{item.locked ? 'blurred' : ''}}" src="{{item.photoUrl}}" mode="aspectFill" />
          <view wx:else class="candidate-photo placeholder">会</view>
          <view class="candidate-main">
            <view class="candidate-title">{{item.title}}　{{item.code}}</view>
            <view class="candidate-summary">{{item.summary}}</view>
            <view class="candidate-tags">
              <text wx:for="{{item.tags}}" wx:key="*this" class="candidate-tag">{{item}}</text>
            </view>
          </view>
          <view class="candidate-arrow">›</view>
        </view>
      </block>
    </view>
  </scroll-view>

  <view class="ask-bar {{inputFocused ? 'focused' : ''}}">
    <textarea
      class="ask-input {{inputFocused ? 'focused' : ''}}"
      value="{{question}}"
      placeholder="输入搜索需求"
      auto-height="{{false}}"
      cursor-spacing="24"
      show-confirm-bar="{{false}}"
      bindinput="handleQuestionInput"
      bindfocus="handleInputFocus"
      bindblur="handleInputBlur"
    ></textarea>
    <button class="ask-button" loading="{{loading}}" disabled="{{loading}}" bindtap="handleAsk">问</button>
  </view>

  <view class="bottom-tabs">
    <block wx:for="{{tabItems}}" wx:key="key">
      <view class="{{item.className}}" data-key="{{item.key}}" bindtap="handleTabTap">
        <image class="tab-icon-image" src="{{item.currentIconUrl}}" mode="aspectFit" />
        <view class="tab-label">{{item.label}}</view>
      </view>
    </block>
  </view>
</view>
