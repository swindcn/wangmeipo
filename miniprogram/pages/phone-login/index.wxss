page {
  background: #ffffff;
}

button {
  margin: 0;
  padding: 0;
  border: none;
}

button::after {
  border: none;
}

.phone-login-page {
  min-height: 100vh;
  padding: 150rpx 80rpx 0;
  background: #ffffff;
  box-sizing: border-box;
}

.brand-logo {
  width: 148rpx;
  height: 148rpx;
  display: block;
  margin: 0 auto;
  border-radius: 50%;
}

.brand-slogan {
  margin-top: 46rpx;
  color: #de8190;
  font-size: 32rpx;
  font-weight: 900;
  text-align: center;
  letter-spacing: 2rpx;
}

.form {
  margin-top: 98rpx;
}

.field-row {
  height: 92rpx;
  display: flex;
  align-items: center;
  border-bottom: 1rpx solid #cccccc;
}

.required {
  color: #d63b3b;
  font-size: 24rpx;
}

.field-label {
  width: 112rpx;
  color: #111111;
  font-size: 26rpx;
}

.field-input {
  flex: 1;
  height: 88rpx;
  color: #222222;
  font-size: 26rpx;
}

.agreement-row {
  display: flex;
  align-items: center;
  gap: 8rpx;
  margin-top: 48rpx;
  color: #b8b8b8;
  font-size: 22rpx;
}

.radio {
  width: 22rpx;
  height: 22rpx;
  border: 1rpx solid #bdbdbd;
  border-radius: 50%;
  box-sizing: border-box;
}

.radio.checked {
  border: 7rpx solid #de8190;
}

.link {
  color: #2f78ff;
}

.login-tip {
  margin-top: 130rpx;
  color: #888888;
  font-size: 24rpx;
  text-align: center;
}

.login-button {
  height: 72rpx;
  margin-top: 132rpx;
  border-radius: 6rpx;
  background: #de8190;
  color: #ffffff;
  font-size: 26rpx;
  font-weight: 800;
  line-height: 72rpx;
}
