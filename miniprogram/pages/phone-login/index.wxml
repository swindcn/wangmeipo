<view class="phone-login-page">
  <image class="brand-logo" src="../../assets/icons/brand-logo.png" mode="aspectFit" />
  <view class="brand-slogan">专业匹配 真诚相亲</view>

  <view class="form">
    <view class="field-row">
      <text class="required">*</text>
      <text class="field-label">手机号</text>
      <input class="field-input" type="number" value="{{phone}}" bindinput="handlePhoneInput" placeholder="请输入手机号" />
    </view>
    <view class="field-row">
      <text class="required">*</text>
      <text class="field-label">密 码</text>
      <input class="field-input" password value="{{password}}" bindinput="handlePasswordInput" placeholder="请输入密码" />
    </view>
  </view>

  <view class="agreement-row" bindtap="toggleAgree">
    <view class="radio {{agreed ? 'checked' : ''}}"></view>
    <text>我已认真阅读并同意</text>
    <text class="link">《用户协议》</text>
    <text>及</text>
    <text class="link">《隐私协议》</text>
  </view>

  <view class="login-tip">未注册的手机号登录后将自动创建账号</view>

  <button class="login-button" loading="{{loading}}" disabled="{{loading}}" bindtap="handleLogin">登录</button>
</view>
