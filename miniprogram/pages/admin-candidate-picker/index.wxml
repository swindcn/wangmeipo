<view class="candidate-picker-page">
  <view class="filter-row">
    <text class="filter-label">性别</text>
    <block wx:for="{{genderFilters}}" wx:key="key">
      <view class="{{item.className}}" data-key="{{item.key}}" bindtap="handleGenderTap">{{item.label}}</view>
    </block>
  </view>

  <view class="search-row">
    <input
      class="search-input"
      placeholder="输入昵称或手机号搜索"
      value="{{keyword}}"
      confirm-type="search"
      bindinput="handleKeywordInput"
      bindconfirm="searchCandidates"
    />
    <button class="search-button" bindtap="searchCandidates">搜索</button>
  </view>

  <view class="candidate-list">
    <block wx:for="{{candidates}}" wx:key="_id">
      <view class="candidate-row" data-id="{{item._id}}" bindtap="handleToggleCandidate">
        <image wx:if="{{item.photoUrl}}" class="candidate-photo" src="{{item.photoUrl}}" mode="aspectFill" />
        <view wx:else class="candidate-photo placeholder">会</view>
        <view class="candidate-main">
          <view class="candidate-title">{{item.title}}</view>
          <view class="candidate-meta">{{item.meta}}</view>
        </view>
        <view class="{{item.checked ? 'check checked' : 'check'}}">✓</view>
      </view>
    </block>
  </view>

  <button class="confirm-button" bindtap="handleConfirm">确定选择</button>
</view>
