<view class="mine-page">
  <view class="mine-nav" style="height: {{navTopGap}}rpx;">
    <view class="mine-nav-title">我的</view>
  </view>

  <view class="mine-content" style="padding-top: {{navTopGap}}rpx;">
    <view class="profile-hero">
      <view class="avatar-wrap">
        <image wx:if="{{profile.avatarUrl}}" class="avatar" src="{{profile.avatarUrl}}" mode="aspectFill" />
        <view wx:else class="avatar placeholder">我</view>
      </view>
      <view class="profile-main">
        <view class="nickname">{{profile.nickname}}</view>
        <view class="role-text">{{profile.roleText}}</view>
      </view>
      <button wx:if="{{profileReady && !profile.registered}}" class="quick-auth-button" bindtap="handleRegisterWithoutPhone" loading="{{registering}}" disabled="{{registering}}">授权登录</button>
    </view>

    <view class="phone-card">
      <view class="phone-left">
        <image class="phone-icon-image" src="../../assets/icons/mine-phone.png" mode="aspectFit" />
        <text class="phone-label">联系方式</text>
      </view>
      <text class="phone-value">{{profile.phoneText}}</text>
    </view>

    <view wx:if="{{profileReady && !profile.registered}}" class="register-card">
      <view class="register-title">完善微信资料</view>
      <view class="register-desc">授权头像、昵称和手机号后，可以查看你传的资料、想看的会员和后续互动记录。</view>

      <view class="register-row">
        <button class="avatar-button" open-type="chooseAvatar" bindchooseavatar="handleChooseAvatar">
          <image wx:if="{{registerProfile.avatarPreview}}" class="register-avatar-image" src="{{registerProfile.avatarPreview}}" mode="aspectFill" />
          <view wx:else class="register-avatar-text">{{registerProfile.initial}}</view>
        </button>
        <input
          class="nickname-input"
          type="nickname"
          value="{{registerProfile.nickname}}"
          bindinput="handleNicknameInput"
          placeholder="填写微信昵称"
        />
      </view>

      <input
        class="phone-input"
        type="number"
        value="{{registerProfile.phone}}"
        bindinput="handlePhoneInput"
        placeholder="可手动填写手机号"
      />
      <button
        class="phone-auth-button"
        loading="{{registering}}"
        disabled="{{registering}}"
        open-type="getPhoneNumber"
        bindgetphonenumber="handlePhoneAuth"
      >
        微信授权手机号
      </button>
      <view class="manual-save" bindtap="handleRegisterWithoutPhone">不授权手机号，保存头像昵称</view>
    </view>

    <view class="section-list">
      <block wx:for="{{sections}}" wx:key="key">
        <view class="section-card">
          <view class="section-header" data-key="{{item.key}}" bindtap="handleOpenSection">
            <view class="section-title-row">
              <view class="section-icon-box">
                <image class="section-icon-image" src="{{item.iconUrl}}" mode="aspectFit" />
              </view>
              <view class="section-title">{{item.title}}</view>
            </view>
            <image class="section-arrow-image" src="../../assets/icons/common-chevron-right.png" mode="aspectFit" />
          </view>

          <view wx:if="{{item.items.length}}" class="thumb-row">
            <block wx:for="{{item.items}}" wx:for-item="profileItem" wx:key="_id">
              <view class="thumb-item" data-id="{{profileItem.candidateId}}" catchtap="handleOpenCandidate">
                <image wx:if="{{profileItem.photoUrl}}" class="thumb-image {{profileItem.locked ? 'blurred' : ''}}" src="{{profileItem.photoUrl}}" mode="aspectFill" />
                <view wx:else class="thumb-image empty-thumb">会</view>
                <view class="thumb-status {{profileItem.statusClass}}">{{profileItem.statusText}}</view>
              </view>
            </block>
          </view>

          <view wx:else class="empty-section">
            <view class="empty-icon">▱</view>
            <view class="empty-text">暂无资料</view>
          </view>
        </view>
      </block>
    </view>
  </view>

  <view class="bottom-tabs">
    <block wx:for="{{tabItems}}" wx:key="key">
      <view class="{{item.className}}" data-key="{{item.key}}" bindtap="handleTabTap">
        <image class="tab-icon-image" src="{{item.currentIconUrl}}" mode="aspectFit" />
        <view class="tab-label">{{item.label}}</view>
      </view>
    </block>
  </view>
</view>
