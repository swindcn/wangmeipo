page {
  background: #ffffff;
}

button {
  margin: 0;
  padding: 0;
  min-width: 0;
  border: none;
}

button::after {
  border: none;
}

.home-page {
  min-height: 100vh;
  background: #ffffff;
  padding-bottom: 150rpx;
  box-sizing: border-box;
}

.top-safe {
  background: #f7f7f7;
}

.search-row {
  display: flex;
  gap: 12rpx;
  padding: 16rpx 24rpx 12rpx;
  background: #ffffff;
}

.search-input {
  flex: 1;
  height: 66rpx;
  padding: 0 22rpx;
  border: 2rpx solid #d5d5d5;
  border-radius: 4rpx;
  color: #222222;
  font-size: 24rpx;
  box-sizing: border-box;
}

.search-button {
  width: 66rpx;
  height: 66rpx;
  min-width: 0;
  flex: 0 0 66rpx;
  border-radius: 6rpx;
  background: #fb5f82;
  color: #ffffff;
  font-size: 34rpx;
  line-height: 66rpx;
  text-align: center;
}

.quick-filter-row {
  display: flex;
  align-items: center;
  gap: 12rpx;
  padding: 0 24rpx 18rpx;
  background: #ffffff;
  overflow-x: auto;
  white-space: nowrap;
  box-sizing: border-box;
}

.quick-filter-chip {
  flex: 0 0 auto;
  height: 48rpx;
  padding: 0 24rpx;
  display: inline-flex;
  align-items: center;
  justify-content: center;
  border-radius: 6rpx;
  background: #e5e5e5;
  color: #151515;
  font-size: 25rpx;
  font-weight: 700;
  line-height: 48rpx;
}

.quick-filter-chip.active {
  background: #e98996;
  color: #ffffff;
}

.quick-filter-clear {
  flex: 0 0 auto;
  width: 48rpx;
  height: 48rpx;
  display: inline-flex;
  align-items: center;
  justify-content: center;
  border-radius: 999rpx;
  background: #9f9f9f;
  color: #ffffff;
  font-size: 42rpx;
  font-weight: 900;
  line-height: 44rpx;
}

.home-loading {
  padding: 80rpx 0 20rpx;
  color: #999999;
  font-size: 26rpx;
  text-align: center;
}

.load-more-text {
  padding: 8rpx 0 36rpx;
  color: #aaaaaa;
  font-size: 24rpx;
  text-align: center;
}

.waterfall {
  display: flex;
  gap: 18rpx;
  padding: 37rpx 24rpx 24rpx;
  box-sizing: border-box;
}

.waterfall-column {
  width: 50%;
  display: flex;
  flex-direction: column;
  gap: 24rpx;
}

.profile-card {
  position: relative;
  width: 100%;
  height: 472rpx;
  border-radius: 12rpx;
  overflow: hidden;
  background: linear-gradient(135deg, #eeeeee, #f7f7f7);
}

.profile-card:nth-child(2n) {
  height: 420rpx;
}

.profile-image {
  width: 100%;
  height: 100%;
  display: block;
  background: #eeeeee;
}

.profile-image-blurred {
  filter: blur(16rpx);
  transform: scale(1.08);
}

.profile-photo-lock {
  position: absolute;
  left: 50%;
  top: 42%;
  transform: translate(-50%, -50%);
  z-index: 2;
  padding: 10rpx 18rpx;
  border-radius: 999rpx;
  background: rgba(0, 0, 0, 0.5);
  color: #ffffff;
  font-size: 22rpx;
  font-weight: 700;
  white-space: nowrap;
}

.profile-overlay {
  position: absolute;
  left: 0;
  right: 0;
  bottom: 0;
  height: 104rpx;
  display: flex;
  align-items: flex-end;
  gap: 18rpx;
  padding: 0 20rpx 18rpx;
  box-sizing: border-box;
  color: #ffffff;
  background: linear-gradient(180deg, rgba(0, 0, 0, 0), rgba(0, 0, 0, 0.62));
}

.profile-basic {
  flex: 0 0 auto;
  height: 38rpx;
  display: flex;
  align-items: center;
  gap: 10rpx;
}

.gender {
  height: 38rpx;
  display: inline-flex;
  align-items: center;
  font-size: 34rpx;
  font-weight: 700;
  line-height: 38rpx;
}

.female {
  color: #ff7892;
}

.male {
  color: #3b89ff;
}

.unknown {
  color: rgba(255, 255, 255, 0.82);
  font-size: 22rpx;
}

.profile-age,
.profile-zodiac {
  height: 38rpx;
  display: inline-flex;
  align-items: center;
  color: #ffffff;
  font-size: 28rpx;
  font-weight: 800;
  line-height: 38rpx;
}

.profile-age {
  min-width: 42rpx;
}

.profile-zodiac {
  min-width: 28rpx;
}

.tag-lines {
  flex: 1;
  display: flex;
  flex-wrap: wrap;
  justify-content: flex-end;
  gap: 6rpx 12rpx;
  max-height: 76rpx;
  overflow: hidden;
}

.profile-tag {
  color: #ffffff;
  font-size: 24rpx;
  font-weight: 700;
  line-height: 34rpx;
}

.bottom-tabs {
  position: fixed;
  left: 0;
  right: 0;
  bottom: 0;
  height: 118rpx;
  display: flex;
  align-items: center;
  justify-content: space-around;
  background: #ffffff;
  border-top: 1rpx solid #dddddd;
  box-shadow: 0 -8rpx 22rpx rgba(0, 0, 0, 0.05);
  z-index: 10;
}

.tab-item {
  width: 20%;
  height: 118rpx;
  display: flex;
  flex-direction: column;
  align-items: center;
  justify-content: center;
  color: #8d8d8d;
  font-size: 22rpx;
  font-weight: 700;
}

.tab-icon-image {
  width: 46rpx;
  height: 46rpx;
  display: block;
}

.tab-label {
  margin-top: 4rpx;
}

.tab-item.active {
  color: #e5798c;
}

.tab-upload {
  transform: translateY(-28rpx);
}

.tab-upload .tab-icon-image {
  width: 116rpx;
  height: 116rpx;
  border-radius: 50%;
  background: #ffffff;
  border: 1rpx solid #dddddd;
  box-shadow: 0 -8rpx 24rpx rgba(0, 0, 0, 0.05);
}

.tab-upload .tab-label {
  margin-top: 0;
  color: #262626;
}
