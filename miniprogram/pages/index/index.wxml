<view class="home-page">
  <view class="top-safe" style="height: {{headerTopGap}}rpx;"></view>

  <view class="search-row">
    <input
      class="search-input"
      placeholder="AI智能搜索"
      value="{{keyword}}"
      confirm-type="search"
      bindinput="handleSearchInput"
      bindconfirm="handleSearch"
    />
    <button class="search-button" bindtap="handleSearch">⌕</button>
  </view>

  <view class="quick-filter-row">
    <block wx:for="{{quickFilterItems}}" wx:key="key">
      <view
        class="{{item.className}}"
        data-key="{{item.key}}"
        bindtap="handleQuickFilterTap"
      >{{item.label}}</view>
    </block>
    <view
      wx:if="{{activeQuickFilters.length}}"
      class="quick-filter-clear"
      bindtap="handleClearQuickFilters"
    >×</view>
  </view>

  <scroll-view
    class="profile-scroll"
    style="height: {{profileScrollHeight}}px;"
    scroll-y
    enhanced
    refresher-enabled
    refresher-triggered="{{refresherTriggered}}"
    bindrefresherrefresh="handleScrollRefresh"
    bindscrolltolower="handleLoadMore"
  >
    <view wx:if="{{loadingProfiles && !hasLoadedProfiles}}" class="home-loading">加载中...</view>
    <view class="waterfall">
      <view class="waterfall-column">
        <block wx:for="{{leftProfiles}}" wx:key="_id">
          <view class="profile-card" data-id="{{item._id}}" bindtap="handleOpenProfile">
            <image class="profile-image {{item.isPrivateLocked ? 'profile-image-blurred' : ''}}" src="{{item.imageUrl}}" mode="aspectFill" lazy-load="true" webp="true" />
            <view wx:if="{{item.showWatermark}}" class="profile-watermark">
              <text>王美婆会员</text><text>王美婆会员</text><text>王美婆会员</text>
              <text>王美婆会员</text><text>王美婆会员</text><text>王美婆会员</text>
            </view>
            <view wx:if="{{item.isPrivateLocked}}" class="profile-photo-lock">照片未开放</view>
            <view class="profile-overlay">
              <view class="profile-basic">
                <text class="profile-age">{{item.age}}</text>
                <text wx:if="{{item.zodiac}}" class="profile-zodiac">{{item.zodiac}}</text>
              </view>
              <view class="tag-lines">
                <text wx:for="{{item.tags}}" wx:key="*this" class="profile-tag">{{item}}</text>
              </view>
            </view>
          </view>
        </block>
      </view>

      <view class="waterfall-column">
        <block wx:for="{{rightProfiles}}" wx:key="_id">
          <view class="profile-card" data-id="{{item._id}}" bindtap="handleOpenProfile">
            <image class="profile-image {{item.isPrivateLocked ? 'profile-image-blurred' : ''}}" src="{{item.imageUrl}}" mode="aspectFill" lazy-load="true" webp="true" />
            <view wx:if="{{item.showWatermark}}" class="profile-watermark">
              <text>王美婆会员</text><text>王美婆会员</text><text>王美婆会员</text>
              <text>王美婆会员</text><text>王美婆会员</text><text>王美婆会员</text>
            </view>
            <view wx:if="{{item.isPrivateLocked}}" class="profile-photo-lock">照片未开放</view>
            <view class="profile-overlay">
              <view class="profile-basic">
                <text class="profile-age">{{item.age}}</text>
                <text wx:if="{{item.zodiac}}" class="profile-zodiac">{{item.zodiac}}</text>
              </view>
              <view class="tag-lines">
                <text wx:for="{{item.tags}}" wx:key="*this" class="profile-tag">{{item}}</text>
              </view>
            </view>
          </view>
        </block>
      </view>
    </view>
    <view wx:if="{{loadingMore}}" class="load-more-text">加载中...</view>
    <view wx:elif="{{hasLoadedProfiles && !hasMoreProfiles && profileOrder.length}}" class="load-more-text">没有更多了</view>
  </scroll-view>

  <view class="bottom-tabs">
    <block wx:for="{{tabItems}}" wx:key="key">
      <view
        class="{{item.className}}"
        data-key="{{item.key}}"
        bindtap="handleTabTap"
      >
        <image class="tab-icon-image" src="{{item.currentIconUrl}}" mode="aspectFit" />
        <view class="tab-label">{{item.label}}</view>
      </view>
    </block>
  </view>
</view>
